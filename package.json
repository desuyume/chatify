{
  "name": "chatify",
  "author": "desuyume <https://t.me/desuyume>",
  "packageManager": "bun@1.3.11",
  "private": true,
  "scripts": {
    "start": "bunx turbo run start",
    "build": "bunx turbo run build",
    "dev": "bunx turbo run dev",
    "db:generate": "bun --filter=@chatify/database run db:generate",
    "db:migrate": "bun --filter=@chatify/database run db:migrate",
    "db:studio": "bun --filter=@chatify/database run db:studio",
    "lint": "bunx turbo run lint",
    "typecheck": "bunx turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,scss}\"",
    "prepare": "husky"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "typescript": "^5.9.3",
      "zod": "^4.3.6",
      "zustand": "^5.0.12",
      "clsx": "^2.1.1",
      "eslint": "^10.1.0",
      "sass": "^1.98.0"
    },
    "catalogs": {
      "build": {
        "tsup": "^8.5.1"
      },
      "lint": {
        "typescript-eslint": "^8.57.1",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1"
      },
      "types": {
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3"
      }
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@desuyume/prettier": "^1.0.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  }
}
