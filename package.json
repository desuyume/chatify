{
  "name": "chatify",
  "private": true,
  "scripts": {
    "start": "dotenv -- turbo run start",
    "build": "dotenv -- turbo run build",
    "dev": "dotenv -- turbo run dev",
    "db:generate": "dotenv -- pnpm --filter=database run db:generate",
    "db:migrate": "dotenv -- pnpm --filter=database run db:migrate",
    "db:studio": "dotenv -- pnpm --filter=database run db:studio",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,scss}\"",
    "prepare": "husky"
  },
  "author": "desuyume <https://t.me/desuyume>",
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@desuyume/prettier": "^1.0.0",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
